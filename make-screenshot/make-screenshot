#!/usr/bin/env bash

PARSED_ARGUMENTS=$(getopt --long 'script:,name:' -n 'make-screenshot' '' "$@")
VALID_ARGUMENTS=$?

if [ $VALID_ARGUMENTS -ne 0 ]; then
    echo 'Terminating...' >&2
    exit 1
fi

eval set -- "$PARSED_ARGUMENTS"

script="/default-showcase.el"

while true; do
    case "$1" in
        --script)
            script="$2"
            shift 2
            ;;
        --name)
            theme_name="$2"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        *)
            echo "Unexpected option: $1"
            exit 1
            ;;
    esac
done

emacs -Q \
    --load /make-screenshot.el \
    --eval "(my-make-screenshot \"${theme_name}\" \"${script}\")"
